{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "diff -q \"${CLAUDE_PLUGIN_ROOT}/scripts/requirements.txt\" \"${CLAUDE_PLUGIN_DATA}/last-installed-requirements.txt\" >/dev/null 2>&1 || (bash \"${CLAUDE_PLUGIN_ROOT}/scripts/run.sh\" --install-only && cp \"${CLAUDE_PLUGIN_ROOT}/scripts/requirements.txt\" \"${CLAUDE_PLUGIN_DATA}/last-installed-requirements.txt\")",
            "async": true
          },
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -Command \"if (-not (Test-Path \\\"${CLAUDE_PLUGIN_DATA}/last-installed-requirements.txt\\\") -or (Compare-Object (Get-Content \\\"${CLAUDE_PLUGIN_ROOT}/scripts/requirements.txt\\\") (Get-Content \\\"${CLAUDE_PLUGIN_DATA}/last-installed-requirements.txt\\\"))) { & \\\"${CLAUDE_PLUGIN_ROOT}/scripts/run.ps1\\\" --install-only; Copy-Item -Force \\\"${CLAUDE_PLUGIN_ROOT}/scripts/requirements.txt\\\" \\\"${CLAUDE_PLUGIN_DATA}/last-installed-requirements.txt\\\" }\"",
            "async": true
          }
        ]
      }
    ]
  }
}
